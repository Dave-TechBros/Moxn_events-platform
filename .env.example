# Environment template. Copy to `.env` and fill in real values.
# IMPORTANT: never commit a `.env` that contains production secrets.

# Database connection string.
# Local/dev uses SQLite (zero external dependencies):
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL) example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/moxn?schema=public"

# Secret used to sign session cookies. Generate a long random string in prod:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="change-me-to-a-long-random-string-in-production"

# Public base URL (used in links / QR deep links if needed).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# How long a ticket HOLD lasts before it is released (minutes).
HOLD_MINUTES="10"
